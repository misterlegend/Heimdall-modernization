{{!< default}}

{{#contentFor "post-styles"}}
    <link href="{{asset "built/css/lightbox.css"}}" rel="stylesheet" type="text/css" />
{{/contentFor}}

{{#post}}
    <div class="{{#if feature_image}}background{{else}}background-pattern bg-white-1 dark:bg-black-1{{/if}} inset-0 absolute overlay overlay-post" {{#if feature_image}}style="background-image: url({{feature_image}});"{{/if}}></div>
    <article class="container article-wrapper px-8 relative z-10 pt-16 lg:pt-24">
        <div class="grid grid-cols-12">
            <div class="col-span-12 lg:col-span-8 col-start-0 lg:col-start-3">
                <header>
                    <h1 class="text-black dark:text-white transition-colors mb-8">{{title}}</h1>
                    <span class="flex items-center">
                        <span class="fill-current text-primary mr-4">{{> "icons/time"}} </span>
                        <time datetime="{{published_at}}" class="font-medium text-gray-700 dark:text-gray-300 transition-colors">{{date format="DD MMM YYYY"}}</time>
                    </span>
                </header>
                <article class="prose dark:prose-dark lg:prose-lg xl:prose-xl border-t border-black border-opacity-5 dark:border-white dark:border-opacity-10 pt-12 mt-12">
                    {{{content}}}
                </article>
            </div>
        </div>
    </article>
{{/post}}

{{#contentFor "post-scripts"}}
    <script src="{{asset "built/js/lightbox.js"}}"></script>
{{/contentFor}}